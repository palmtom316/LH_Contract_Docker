# LH Contract Management System - Environment Configuration
# Copy this file to .env and modify the values

# ===================
# Application Settings
# ===================
APP_NAME=LH Contract Management System
APP_VERSION=1.6
DEBUG=false

# ===================
# Database Configuration
# ===================
# PostgreSQL connection string
POSTGRES_USER=lh_admin
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
POSTGRES_DB=lh_contract_db
DATABASE_URL=postgresql+asyncpg://lh_admin:CHANGE_THIS_TO_A_STRONG_PASSWORD@db:5432/lh_contract_db

# ===================
# Security Settings
# ===================
# IMPORTANT: Generate a strong secret key for production!
# You can generate one with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY
INIT_ADMIN_TOKEN=CHANGE_THIS_TO_A_ONE_TIME_ADMIN_BOOTSTRAP_TOKEN

# JWT token expiration (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===================
# CORS Configuration
# ===================
# Comma-separated list of allowed origins
# IMPORTANT: In production, set this to your actual domain(s)
# Example for LAN deployment: http://192.168.1.100,http://192.168.1.100:80
# Example for domain: https://contract.yourcompany.com
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ===================
# File Upload Settings
# ===================
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=52428800
TRUSTED_PROXIES=

# 宿主机文件存储路径（可选，用于外部存储）
# 如果使用外部存储或NFS挂载，设置此变量
# 示例：HOST_UPLOAD_DIR=/mnt/data/contract_uploads
# HOST_UPLOAD_DIR=./uploads

# ===================
# MinIO Storage (V1.5+)
# ===================
# MinIO S3-compatible object storage configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
# Internal endpoint (used by backend within Docker network)
MINIO_ENDPOINT=minio:9000
# External endpoint (for browser access)
MINIO_EXTERNAL_ENDPOINT=http://localhost:9000
MINIO_BUCKET_ACTIVE=contracts-active
MINIO_BUCKET_ARCHIVE=contracts-archive

# ===================
# Supabase Configuration (V1.5+)
# ===================
# JWT secret for Supabase Auth (at least 32 characters)
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

# Supabase API Keys (generate these or use default demo keys for dev)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# External URLs
SUPABASE_PUBLIC_URL=http://localhost:8001
API_EXTERNAL_URL=http://localhost:8001
SITE_URL=http://localhost:3000

# Email configuration (optional, for auth emails)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_ADMIN_EMAIL=admin@example.com

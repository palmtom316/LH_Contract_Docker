# LH Contract Management System - Production Environment Configuration
# 生产环境配置文件模板
# 
# 重要提示：
# 1. 复制此文件为 .env.production
# 2. 修改所有标记为 CHANGE_THIS 的值
# 3. 不要将 .env.production 提交到 Git（已在 .gitignore 中）

# ===================
# Application Settings
# ===================
APP_NAME=LH Contract Management System
APP_VERSION=1.6.3
DEBUG=false

# ===================
# Database Configuration
# ===================
# 数据库用户名
POSTGRES_USER=lh_admin

# ⚠️ 必须修改：使用强密码（至少16位，包含大小写字母、数字、特殊字符）
# 生成强密码示例：openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD_MIN_16_CHARS

# 数据库名称
POSTGRES_DB=lh_contract_db

# 数据库连接字符串（使用容器服务名 'db'）
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ===================
# Security Settings
# ===================
# ⚠️ 必须修改：生成强密钥
# 生成命令：python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_USE_COMMAND_ABOVE
INIT_ADMIN_TOKEN=CHANGE_THIS_TO_A_ONE_TIME_ADMIN_BOOTSTRAP_TOKEN
ENABLE_API_DOCS=false

# JWT token 过期时间（分钟）
# 生产环境建议设置较短的过期时间
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ===================
# CORS Configuration
# ===================
# ⚠️ 必须修改：设置为实际的生产域名
# 多个域名用逗号分隔，不要有空格
# 示例：https://contract.yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=CHANGE_THIS_TO_YOUR_PRODUCTION_DOMAIN

# ===================
# Redis Configuration
# ===================
# Redis 连接字符串（使用容器服务名 'redis'）
REDIS_URL=redis://redis:6379/0

# 缓存配置
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=300
TRUSTED_PROXIES=

# ===================
# File Upload Settings
# ===================
# 上传目录（容器内路径）
UPLOAD_DIR=/app/uploads

# 最大文件大小（字节）50MB
MAX_FILE_SIZE=52428800

# 宿主机文件存储路径（可选，用于外部存储）
# 如果使用外部存储或NFS挂载，设置此变量
# 示例：HOST_UPLOAD_DIR=/mnt/data/contract_uploads
# HOST_UPLOAD_DIR=./uploads

# ===================
# Uvicorn Workers
# ===================
# 工作进程数量（建议设置为 CPU 核心数）
WORKERS=4

# ===================
# 部署检查清单
# ===================
# 在部署前，请确认以下事项：
# 
# [ ] 已修改 POSTGRES_PASSWORD 为强密码
# [ ] 已生成并设置 SECRET_KEY
# [ ] 已设置正确的 CORS_ORIGINS 为生产域名
# [ ] 已配置 Nginx 反向代理
# [ ] 已配置 SSL 证书
# [ ] 已创建数据备份策略
# [ ] 已测试健康检查端点
# [ ] 已配置防火墙规则（只开放 80 和 443 端口）
# [ ] 已配置日志收集和监控
# [ ] 已准备回滚方案
